RAG_APP__ENV=development
RAG_LOGGING__LEVEL=INFO
RAG_APP__HOST=0.0.0.0
RAG_APP__PORT=8000
RAG_INGESTION__INPUT_DIR=data/raw
RAG_INGESTION__OUTPUT_DIR=data/processed
RAG_INDEXING__INPUT_CHUNK_FILE=data/processed/chunks.jsonl
RAG_INDEXING__OUTPUT_DIR=data/indexes
RAG_INDEXING__EMBEDDING_PROVIDER=sentence_transformers
RAG_INDEXING__EMBEDDING_VERSION=v1
RAG_QUERY__ENABLE_EXPANSION=true
RAG_QUERY__ENABLE_LLM_FALLBACK=true
RAG_RETRIEVAL__MANIFEST_PATH=data/indexes/v1/manifest.json
RAG_RETRIEVAL__DENSE_TOP_K=8
RAG_RETRIEVAL__SPARSE_TOP_K=8
RAG_RETRIEVAL__FUSED_TOP_K=10
RAG_RERANKING__PROVIDER=cross_encoder
RAG_RERANKING__TOP_K=5
RAG_CONTEXT__MAX_CONTEXT_TOKENS=700
RAG_CONTEXT__MAX_CHUNKS=4
RAG_GENERATION__PROVIDER=openai
RAG_GENERATION__FALLBACK_PROVIDER=heuristic
RAG_GENERATION__MAX_CITATIONS=4
RAG_POSTPROCESSING__HIGH_CONFIDENCE_THRESHOLD=0.8
RAG_POSTPROCESSING__MEDIUM_CONFIDENCE_THRESHOLD=0.55
RAG_OPENAI__API_KEY=
RAG_OPENAI__MODEL=gpt-4.1-mini
